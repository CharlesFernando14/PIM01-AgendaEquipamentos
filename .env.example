# Exemplo de configuração de variáveis de ambiente
# Copie este arquivo para .env.local e preencha com seus valores reais

# Database - PostgreSQL
DATABASE_URL="postgresql://usuario:senha@localhost:5432/equipa_agenda_escola?schema=public"

# JWT Secret - chave secreta para tokens de autenticação
JWT_SECRET="uma-chave-secreta-qualquer"

# Next.js
# NODE_ENV=development
# NEXT_PUBLIC_APP_URL=http://localhost:3000

# Autenticação — JWT Secret (altere em produção!)
JWT_SECRET="equipa-secret-key-change-in-production"

# Adicione outras variáveis de ambiente aqui conforme necessário
